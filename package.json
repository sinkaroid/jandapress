{
  "name": "jandapress",
  "version": "10.0.2-alpha",
  "description": "RESTful and experimental API for the Doujinshi, Pressing the whole nhentai, pururin, hentaifox, and more.",
  "main": "build/src/index.js",
  "scripts": {
    "build": "bunx tsc",
    "start": "bun run src/index.ts",
    "start:prod": "bun run build/src/index.js",
    "start:dev": "bun run --watch src/index.ts",
    "lint": "bunx eslint . --ext .ts",
    "lint:fix": "bunx eslint . --fix",
    "test:scrape": "bun run test/test.ts",
    "test": "bun run test/nh.ts",
    "test:nhentai": "bun test test/jandapress.test.ts --test-name-pattern=^nhentai$",
    "test:pururin": "bun test test/jandapress.test.ts --test-name-pattern=^pururin$",
    "test:hentaifox": "bun test test/jandapress.test.ts --test-name-pattern=^hentaifox$",
    "test:asmhentai": "bun test test/jandapress.test.ts --test-name-pattern=^asmhentai$",
    "test:hentai2read": "bun test test/jandapress.test.ts --test-name-pattern=^hentai2read$",
    "test:simply-hentai": "bun test test/jandapress.test.ts --test-name-pattern=^simply-hentai$",
    "test:3hentai": "bun test test/jandapress.test.ts --test-name-pattern=^3hentai$"
  },
  "keywords": [],
  "author": "sinkaroid",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sinkaroid/jandapress.git"
  },
  "license": "MIT",
  "dependencies": {
    "@keyv/redis": "^5.1.6",
    "cheerio": "^1.2.0",
    "hono": "^4.9.9",
    "keyv": "^5.6.0",
    "@hono/swagger-ui": "^0.5.2",
    "@hono/zod-openapi": "^0.19.10",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.38.0",
    "globals": "^17.5.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.13"
  },
  "packageManager": "bun@1.3.13"
}
