{
  "name": "jandapress",
  "version": "7.0.1-alpha",
  "description": "RESTful and experimental API for the Doujinshi, Pressing the whole nhentai, pururin, hentaifox, and more.",
  "main": "build/src/index.js",
  "scripts": {
    "build": "rimraf build && tsc",
    "start": "node build/src/index.js",
    "start:prod": "npm run build && node build/src/index.js",
    "start:dev": "ts-node-dev src/index.ts",
    "lint": "npx eslint . --ext .ts",
    "lint:fix": "npx eslint . --fix",
    "build:freshdoc": "rimraf docs",
    "build:apidoc": "npm run build:freshdoc && npx apidoc -i src -o docs",
    "test:scrape": "ts-node test/test.ts",
    "test:cf": "ts-node test/nhentaiCookietest.ts",
    "test:nhentai": "npx start-server-and-test 3000 \"curl -v http://localhost:3000/nhentai/get?book=577774 | jq '.'\"",
    "test:pururin": "start-server-and-test \"npm run start:dev\" 3000 \"node -r ts-node/register --test --test-name-pattern=^pururin$ test/jandapress.test.ts\"",
    "test:hentaifox": "start-server-and-test \"npm run start:dev\" 3000 \"node -r ts-node/register --test --test-name-pattern=^hentaifox$ test/jandapress.test.ts\"",
    "test:asmhentai": "start-server-and-test \"npm run start:dev\" 3000 \"node -r ts-node/register --test --test-name-pattern=^asmhentai$ test/jandapress.test.ts\"",
    "test:hentai2read": "start-server-and-test \"npm run start:dev\" 3000 \"node -r ts-node/register --test --test-name-pattern=^hentai2read$ test/jandapress.test.ts\"",
    "test:simply-hentai": "start-server-and-test \"npm run start:dev\" 3000 \"node -r ts-node/register --test --test-name-pattern=^simply-hentai$ test/jandapress.test.ts\"",
    "test:3hentai": "start-server-and-test \"npm run start:dev\" 3000 \"node -r ts-node/register --test --test-name-pattern=^3hentai$ test/jandapress.test.ts\""
  },
  "apidoc": {
    "title": "Jandapress API Documentation",
    "url": "https://janda.sinkaroid.org",
    "sampleUrl": "https://janda.sinkaroid.org",
    "name": "Jandapress"
  },
  "keywords": [],
  "author": "sinkaroid",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sinkaroid/jandapress.git"
  },
  "license": "MIT",
  "dependencies": {
    "@keyv/redis": "^5.1.6",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-slow-down": "^3.0.1",
    "http-cookie-agent": "^7.0.3",
    "keyv": "^5.6.0",
    "phin": "^3.7.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tough-cookie": "^6.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "@types/tough-cookie": "^4.0.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "apidoc": "^1.2.0",
    "eslint": "^10.0.3",
    "rimraf": "^6.1.3",
    "start-server-and-test": "^2.1.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}